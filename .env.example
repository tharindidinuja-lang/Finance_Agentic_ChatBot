# .env.example
# ============================================================================
# FINANCE AGENTIC CHATBOT - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# ============================================================================

# ============================================================================
# LLM API KEYS
# ============================================================================

# OpenAI Configuration (Required for default setup)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=2000

# Anthropic Claude (Optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229
LLM_PROVIDER=openai

# ============================================================================
# FINANCIAL DATA APIS
# ============================================================================

ALPHA_VANTAGE_API_KEY=
YAHOO_FINANCE_ENABLED=true
EXCHANGERATE_API_KEY=

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

APP_ENV=development
APP_DEBUG=true
DATA_DIR=data
LOGS_DIR=logs

# ============================================================================
# SECURITY (CHANGE THESE IN PRODUCTION!)
# ============================================================================

JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRATION_HOURS=24

# ============================================================================
# FEATURE FLAGS
# ============================================================================

ENABLE_FRAUD_DETECTION=true
ENABLE_HUMAN_REVIEW=true
ENABLE_AUDIT_LOGGING=true

# ============================================================================
# TRANSACTION LIMITS
# ============================================================================

DAILY_TRANSFER_LIMIT=10000.0
MONTHLY_TRANSFER_LIMIT=50000.0
MAX_SINGLE_TRANSFER=50000.0
HUMAN_REVIEW_AMOUNT=10000.0

# ============================================================================
# RISK THRESHOLDS
# ============================================================================

RISK_HIGH_THRESHOLD=70
RISK_MEDIUM_THRESHOLD=40

# ============================================================================
# RETRY CONFIGURATION
# ============================================================================

MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_BASE=1.0
RETRY_BACKOFF_MAX=10.0

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_CONSOLE=true
LOG_FILE=true
LOG_JSON=false